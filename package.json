{
  "name": "ascet-copilot",
  "displayName": "ASCET Copilot",
  "description": "AI-powered assistant for ASCET projects",
  "version": "0.2.0",
  "publisher": "ascet-copilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/ascet-copilot/ascet-copilot"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "ascet",
        "name": "ascet",
        "fullName": "ASCET Copilot",
        "description": "Hỏi về class, calc code và block diagram trong ASCET Database",
        "isSticky": true,
        "commands": [
          {
            "name": "analyze",
            "description": "Phan tich calc code cua mot ASCET class"
          },
          {
            "name": "list",
            "description": "Liet ke toan bo class trong database"
          },
          {
            "name": "diagram",
            "description": "Doc va mo ta block diagram cua mot class"
          },
          {
            "name": "dsd",
            "description": "Xuat file Excel DSD cho mot class hoac toan bo"
          },
          {
            "name": "ai",
            "description": "Kiem tra day du: rule + AI review (analyze_code)"
          },
          {
            "name": "rag",
            "description": "Tim kiem trong RAG knowledge base"
          },
          {
            "name": "context",
            "description": "Xem system prompt va calc code (debug)"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "ascet.refresh",
        "title": "ASCET: Refresh Class List",
        "icon": "$(refresh)"
      },
      {
        "command": "ascet.selectAndChat",
        "title": "ASCET: Search & Analyze Class",
        "icon": "$(search)"
      },
      {
        "command": "ascet.analyzeSelected",
        "title": "ASCET: Analyze This Class",
        "icon": "$(play)"
      },
      {
        "command": "ascet.askCopilot",
        "title": "Ask ASCET Copilot",
        "icon": "$(copilot)"
      },
      {
        "command": "ascet.openLog",
        "title": "ASCET: Show Log Panel",
        "icon": "$(output)"
      },
      {
        "command": "ascet.exportDsd",
        "title": "ASCET: Export DSD to Excel",
        "icon": "$(file-excel)"
      },
      {
        "command": "ascet.runAiReview",
        "title": "ASCET: AI Review",
        "icon": "$(beaker)"
      },
      {
        "command": "ascet.addToQueue",
        "title": "ASCET: Add to Scan Queue",
        "icon": "$(add)"
      },
      {
        "command": "ascet.showQueue",
        "title": "ASCET: Show Scan Queue",
        "icon": "$(list-ordered)"
      },
      {
        "command": "ascet.clearQueue",
        "title": "ASCET: Clear Scan Queue",
        "icon": "$(trash)"
      },
      {
        "command": "ascet.showDiagram",
        "title": "ASCET: Show Block Diagram",
        "icon": "$(symbol-class)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ascet.refresh",
          "when": "view == ascetClassTree",
          "group": "navigation@1"
        },
        {
          "command": "ascet.selectAndChat",
          "when": "view == ascetClassTree",
          "group": "navigation@2"
        },
        {
          "command": "ascet.showQueue",
          "when": "view == ascetClassTree",
          "group": "navigation@3"
        },
        {
          "command": "ascet.openLog",
          "when": "view == ascetClassTree",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "ascet.analyzeSelected",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@1"
        },
        {
          "command": "ascet.runAiReview",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@2"
        },
        {
          "command": "ascet.showDiagram",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@3"
        },
        {
          "command": "ascet.exportDsd",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@4"
        },
        {
          "command": "ascet.addToQueue",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@5"
        },
        {
          "command": "ascet.askCopilot",
          "when": "view == ascetClassTree && viewItem == ascetClass",
          "group": "ascet@6"
        }
      ],
      "commandPalette": [
        { "command": "ascet.refresh" },
        { "command": "ascet.selectAndChat" },
        { "command": "ascet.openLog" },
        { "command": "ascet.showQueue" },
        { "command": "ascet.clearQueue" },
        { "command": "ascet.exportDsd" },
        { "command": "ascet.analyzeSelected", "when": "false" },
        { "command": "ascet.askCopilot", "when": "false" },
        { "command": "ascet.runAiReview", "when": "false" },
        { "command": "ascet.addToQueue", "when": "false" },
        { "command": "ascet.showDiagram", "when": "false" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ascetContainer",
          "title": "ASCET Copilot",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "ascetContainer": [
        {
          "id": "ascetClassTree",
          "name": "ASCET Classes",
          "icon": "$(database)",
          "contextualTitle": "ASCET Database"
        }
      ]
    },
    "configuration": {
      "title": "ASCET Copilot",
      "properties": {
        "ascetCopilot.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable (e.g. C:\\miniconda3\\envs\\py39_env\\python.exe)."
        },
        "ascetCopilot.ascetVersion": {
          "type": "string",
          "default": "auto",
          "description": "ASCET COM version string, e.g. 6.1.5. Use \"auto\" to auto-detect."
        },
        "ascetCopilot.cliBinPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to `ascet_cli.exe`. Leave **empty** to use the bundled `bin/ascet_cli.exe` shipped with this extension (default behaviour)."
        }
      }
    }
  },
  "files": [
    "out/**",
    "bin/**",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@secretlint/node": "^13.0.2",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  }
}
